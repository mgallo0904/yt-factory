# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# Ollama-compatible API endpoint (e.g., OpenRouter, cloud Ollama)
# LLM_API_BASE=https://ollama.com/v1/chat/completions
# LLM_API_KEY=your_key_here

# Optional: Pexels free stock footage API key
# PEXELS_API_KEY=your_key_here

# Optional: YouTube upload via API (requires Google OAuth)
# YOUTUBE_CLIENT_SECRET_FILE=client_secret.json
